# ReportItNow POC configuration
# Copy to .env and fill in. Never commit .env.

# --- LLM (local Qwen via OpenAI-compatible endpoint, e.g. Ollama / LM Studio / vLLM) ---
LLM_ENDPOINT=http://localhost:11434/v1
LLM_MODEL=qwen3:30b-a3b
LLM_API_KEY=ollama
LLM_REQUEST_TIMEOUT_S=120

# Set to 1 to force deterministic stub outputs instead of calling the LLM
LLM_STUB_MODE=0

# --- Database ---
# NB: do NOT use DATABASE_URL — Chainlit 2.x reserves that env var to enable
# its own Postgres-backed data layer (it would try to `import asyncpg`).
REPORTITNOW_DATABASE_URL=sqlite:///./data/reportitnow.db

# --- Secrets ---
# Used to chain audit log entries (HMAC-SHA256). In prod this lives in an HSM.
AUDIT_CHAIN_HMAC_KEY=dev-only-change-me-please-32-bytes-min-xxxxx
# Signs Chainlit -> FastAPI service tokens
SERVICE_TOKEN_SECRET=dev-only-service-token-secret-change-me
# Chainlit JWT secret for password auth (required by Chainlit). The run.sh
# script auto-fills this in .env on first 'up' if you leave it blank here.
CHAINLIT_AUTH_SECRET=

# --- FastAPI ---
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000
FASTAPI_BASE_URL=http://127.0.0.1:8000

# --- DP engine defaults (§7.2) ---
DP_EPSILON_COUNT=0.5
DP_EPSILON_RATE=0.5
DP_EPSILON_TIME=0.5
DP_MAX_RESOLUTION_DAYS=150
DP_WORKFORCE_FLOOR=50
